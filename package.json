{
  "name": "pi-btw-extension",
  "version": "0.1.0",
  "description": "Ask a side question grounded in your live pi session, without polluting the main conversation.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "side-question"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@earendil-works/pi-ai": "*"
  },
  "scripts": {
    "typecheck": "./scripts/link-pi-types.sh && tsc --noEmit -p tsconfig.json",
    "test": "tests/btw-store.sh && tests/btw-replay.sh && tests/btw-promote.sh"
  }
}
